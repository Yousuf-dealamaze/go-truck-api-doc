meta {
  name: Get Revenue By Region
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/booking-master/revenue-by-region
  body: none
  auth: inherit
}

docs {
  Returns total revenue aggregated by region for standard bookings.
  
  **Data Returned:**
  * `regionName`: Name of the from region
  * `totalRevenue`: Sum of totalAmount for that region
  * `totalBookings`: Count of bookings in that region
}
