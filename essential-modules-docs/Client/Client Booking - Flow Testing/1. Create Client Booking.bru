meta {
  name: 1. Create Client Booking
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/booking-client-master
  body: json
  auth: inherit
}

body:json {
  {
    "userId": "7c2ac029-af9f-4516-a3e3-105e6a18401d",
    "vehiclesQuantity": 1,
    "pickupAddressId": "0428daed-bd64-47ec-9a6c-793b2a3b988c",
    "dropAddressId": "0428daed-bd64-47ec-9a6c-793b2a3b988c",
    "clientPricingId": "90596350-019a-4c9f-8be3-a4c0ca6f6c8d",
    "bookingMode": "Instant",
    "currencyCode": "SAR",
    "status": "CREATED"
  }
}

script:post-response {
  if (res.body && res.body.data && res.body.data.id) {
    bru.setEnvVar("clientBookingId", res.body.data.id);
  }
}
