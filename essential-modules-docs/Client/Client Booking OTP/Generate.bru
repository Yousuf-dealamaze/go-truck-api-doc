meta {
  name: Generate OTP
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/client-booking-otp/generate
  body: json
  auth: inherit
}

body:json {
  {
    "clientBookingId": "",
    "otpType": "DELIVERY"
  }
}

docs {
  Generates a 6-digit randomized secure OTP for the specified booking. 
  - otpType: 'DELIVERY' (Used to start the delivery process by transitioning status from 'AT_PICKUP' to 'IN_TRANSIT' upon successful verification)
  - Valid for 10 minutes.
}
