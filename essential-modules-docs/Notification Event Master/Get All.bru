meta {
  name: Get All
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/notification-event-master/all
  body: none
  auth: inherit
}

params:query {
  ~page: 1
  ~limit: 10
  ~status: active
  ~module: BOOKING
  ~categoryId: 
}

docs {
  Retrieves all notification events with pagination and filtering.
  
  **Query Parameters:**
  * `page` (number, optional): Page number (default: 1)
  * `limit` (number, optional): Items per page (default: 10)
  * `status` (string, optional): Filter by status ('active', 'inactive')
  * `module` (string, optional): Filter by module name
  * `categoryId` (uuid, optional): Filter by category ID
}

