meta {
  name: Export PDF
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/billing-invoice-master/{{invoiceId}}/pdf
  body: none
  auth: inherit
}

vars:pre-request {
  invoiceId: 8cc332a0-d9c2-4570-adfd-a5a922e27fe3
}

docs {
  ### Export Invoice PDF
  Generates and downloads a real TAX-INVOICE PDF for the specified Invoice ID.
  
  **Note**: This endpoint requires a valid authentication token and the requester must be authorized to view the invoice (e.g., the owner or a transporter).
}
